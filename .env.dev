# ── Geo-based billing routing ─────────────────────────────────────────
# JSON config for provider routing by client geography.
# First matching rule wins. Unmatched requests use default_provider.
# Requires GEOLITE2_DB_PATH for IP-to-country lookup.
BILLING_GEO_RULES='{"default_provider":"stripe","rules":[{"provider":"razorpay","include_countries":["IN"],"include_continents":["AS"],"exclude_countries":["CN"]},{"provider":"mercado_pago","include_continents":["SA"]},{"provider":"revolut","include_continents":["EU"]},{"provider":"airwallex","include_countries":["AU","NZ","SG","HK","JP"]},{"provider":"paypal","include_countries":["US","CA","GB"]}]}'

# Path to MaxMind GeoLite2-Country.mmdb (optional — missing = no geo routing)
GEOLITE2_DB_PATH=

